# Google API Key (AI Studio)
# You can get this from https://aistudio.google.com/
GOOGLE_API_KEY=your_key_here

# Google Cloud Vertex AI (Optional for Live Images / Animated Videos)
# Setting this to true will use Vertex AI Imagen 2 to generate 4s clips.
# Requires a GCP Project with billing and Vertex AI API enabled.
USE_VERTEX_AI=false
GCP_PROJECT_ID=your_project_id_here
GCP_LOCATION=us-central1
